# Database
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secret (genera uno seguro en producción)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Rate Limiting
RATE_LIMIT_WINDOW="60" # segundos
RATE_LIMIT_MAX_REQUESTS="100"

# Payment Providers
# Webpay (Transbank - Chile)
WEBPAY_COMMERCE_CODE=""
WEBPAY_API_KEY=""
WEBPAY_ENVIRONMENT="integration" # integration | production

# Stripe (opcional)
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (opcional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# File Storage (opcional)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# Logging
LOG_LEVEL="info" # debug | info | warn | error
