# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_PORT=3000

# ============================================
# DATABASE - PostgreSQL
# ============================================
DATABASE_URL="postgresql://marketplace_user:change_this_password@localhost:5432/marketplace?schema=public"
DB_NAME=marketplace
DB_USER=marketplace_user
DB_PASSWORD=change_this_password
DB_HOST=localhost
DB_PORT=5432

# ============================================
# REDIS - Cache & Queues
# ============================================
REDIS_URL="redis://:redis_password@localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-change-this"
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET="your-session-secret-change-this"
SESSION_MAX_AGE=604800000

# ============================================
# PAYMENT PROVIDERS
# ============================================

# Webpay (Transbank - Chile)
WEBPAY_COMMERCE_CODE=""
WEBPAY_API_KEY=""
WEBPAY_ENVIRONMENT=integration
WEBPAY_CALLBACK_URL=http://localhost:3000/api/payments/webpay/callback
WEBPAY_RETURN_URL=http://localhost:3000/checkout/success

# Stripe (International)
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# MercadoPago (LATAM)
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ============================================
# GOOGLE SERVICES
# ============================================

# Google Maps API (para tracking de maquinaria y geocoding)
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_GEOCODING_API_KEY=""

# Google Places API (para autocompletar direcciones)
GOOGLE_PLACES_API_KEY=""

# Google OAuth (opcional - autenticación social)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# GPS & TRACKING (para fleet items)
# ============================================
GPS_TRACKING_ENABLED=false
GPS_UPDATE_INTERVAL=300000
GPS_GEOFENCE_RADIUS=5000
GPS_PROVIDER=google

# ============================================
# EMAIL / SMTP
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@marketplace.cl"
EMAIL_FROM_NAME="Marketplace"

# SendGrid (alternativa)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""

# ============================================
# FILE STORAGE - AWS S3
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_PUBLIC_URL=""

# Cloudinary (alternativa para imágenes)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================
# NOTIFICATIONS
# ============================================

# SMS - Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Push Notifications - Firebase
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_DATABASE_URL=""

# WhatsApp Business API
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry (Error Tracking)
SENTRY_DSN=""
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_DSN=""

# Datadog (APM & Monitoring)
DATADOG_API_KEY=""
DATADOG_APP_KEY=""

# New Relic
NEW_RELIC_LICENSE_KEY=""
NEW_RELIC_APP_NAME="Marketplace Híbrido"

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_RENTALS=true
ENABLE_SERVICES=true
ENABLE_GPS_TRACKING=false
ENABLE_ESCROW=true
ENABLE_REVIEWS=true
ENABLE_CHAT=false
ENABLE_ANALYTICS=true

# ============================================
# BUSINESS LOGIC CONFIG
# ============================================

# Rental Configuration
RENTAL_MIN_DAYS=1
RENTAL_MAX_DAYS=90
RENTAL_DEPOSIT_PERCENTAGE=0.20
RENTAL_LATE_PENALTY_PER_DAY=100000
RENTAL_INSPECTION_REQUIRED=true

# Service Configuration
SERVICE_MIN_BOOKING_HOURS=2
SERVICE_CANCELLATION_HOURS=24
SERVICE_TECHNICIAN_RADIUS_KM=50

# Escrow Configuration
ESCROW_HOLD_DAYS=7
PLATFORM_FEE_PERCENTAGE=0.10
SELLER_MIN_PAYOUT=50000

# ============================================
# DOCKER CONFIGURATION (para docker-compose)
# ============================================
BUILD_TARGET=development
COMPOSE_PROJECT_NAME=marketplace

# PGAdmin (opcional)
PGADMIN_EMAIL=admin@marketplace.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Redis Commander (opcional)
REDIS_COMMANDER_PORT=8081

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# CRON JOBS & BACKGROUND TASKS
# ============================================
ENABLE_CRON_JOBS=true
CRON_OVERDUE_RENTALS="0 */6 * * *"
CRON_CLEANUP_SESSIONS="0 0 * * *"
CRON_BACKUP_DATABASE="0 2 * * *"
