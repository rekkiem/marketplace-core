// ============================================
// DISPUTES & RESOLUTIONS
// ============================================

enum DisputeType {
  RENTAL_DAMAGE
  SERVICE_NOT_COMPLETED
  PRODUCT_NOT_AS_DESCRIBED
  DELIVERY_ISSUE
  DEPOSIT_REFUND
  OTHER
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  AWAITING_EVIDENCE
  RESOLVED
  ESCALATED
  CLOSED
}

model Dispute {
  id              String        @id @default(cuid())
  
  // Reference
  orderId         String?
  rentalId        String?
  bookingId       String?
  
  // Parties
  claimantId      String        // Usuario que abre disputa
  defendantId     String        // Seller/técnico
  
  // Type
  type            DisputeType
  status          DisputeStatus @default(OPEN)
  
  // Description
  title           String
  description     String        @db.Text
  evidence        String[]      // URLs
  
  // Amount
  disputedAmount  Float
  
  // Resolution
  resolution      String?       @db.Text
  resolvedBy      String?       // Admin ID
  resolvedAt      DateTime?
  
  // Outcome
  refundAmount    Float?
  compensationAmount Float?
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  messages        DisputeMessage[]
  
  @@index([orderId])
  @@index([rentalId])
  @@index([bookingId])
  @@index([status])
  @@map("disputes")
}

model DisputeMessage {
  id          String    @id @default(cuid())
  disputeId   String
  dispute     Dispute   @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  senderId    String
  message     String    @db.Text
  attachments String[]
  
  createdAt   DateTime  @default(now())
  
  @@index([disputeId])
  @@map("dispute_messages")
}

