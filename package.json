{
  "name": "marketplace-hybrid",
  "version": "1.0.0",
  "description": "Marketplace Híbrido de Construcción - Productos + Servicios + Arriendos",
  "private": true,
  "author": "Tu Empresa",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "========== DEVELOPMENT ==========": "",
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    
    "========== BUILD & PRODUCTION ==========": "",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start -p ${PORT:-3000}",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "stop:pm2": "pm2 stop marketplace",
    "restart:pm2": "pm2 restart marketplace",
    "reload:pm2": "pm2 reload marketplace",
    "logs:pm2": "pm2 logs marketplace",
    "monit:pm2": "pm2 monit",
    
    "========== DATABASE ==========": "",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    
    "========== TESTING ==========": "",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    
    "========== CODE QUALITY ==========": "",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    
    "========== DOCKER ==========": "",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:rebuild": "docker-compose down && docker-compose build --no-cache && docker-compose up -d",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    
    "========== DEPLOYMENT ==========": "",
    "deploy:staging": "pm2 deploy ecosystem.config.js staging",
    "deploy:production": "pm2 deploy ecosystem.config.js production",
    "deploy:setup": "pm2 deploy ecosystem.config.js production setup",
    
    "========== UTILITIES ==========": "",
    "clean": "rm -rf .next node_modules .turbo",
    "clean:logs": "rm -rf logs/*.log",
    "clean:all": "npm run clean && npm run clean:logs",
    "postinstall": "prisma generate",
    "prepare": "husky install || true",
    
    "========== HEALTH & MONITORING ==========": "",
    "health": "curl http://localhost:3000/api/health",
    "status": "pm2 status",
    "logs": "tail -f logs/*.log"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "@t3-oss/env-nextjs": "^0.9.2",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.3.2",
    "jose": "^5.2.2",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.22.4",
    "dotenv": "^16.4.1",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "@playwright/test": "^1.41.0",
    "jest": "^29.7.0",
    "prisma": "^5.9.1",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.4",
    "eslint": "^8.56.0",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
